{
  "name": "my-astro-project",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.astro": "eslint --max-warnings 0"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "lint": "eslint \"src/**/*.astro\"",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "astro build && vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.1",
    "@expressive-code/plugin-line-numbers": "^0.44.0",
    "@shikijs/transformers": "^4.3.1",
    "astro": "^7.0.6",
    "astro-expressive-code": "^0.44.0",
    "astro-seo": "^1.1.0",
    "gsap": "^3.12.5",
    "mdast-util-to-string": "^4.0.0",
    "reading-time": "^1.5.0",
    "sharp": "^0.33.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "lint-staged": "^17.0.8",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.9"
  }
}