---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const { slug } = Astro.params;

export async function getStaticPaths() {
	const posts = await getCollection("posts", ({ data }) => data.draft !== true);
	return [...new Set(posts.map((post) => post.data.tags).flat())].map((tag) => ({
		params: { slug: tag },
	}));
}

if (!slug) {
	return Astro.redirect("/404");
}

const catFor = (tags?: string[]) =>
	tags?.includes("accessibility") ? "accessibility" : "creative";

const published = await getCollection("posts", ({ data }) => data.draft !== true);

const matching = published
	.filter((post) => post.data.tags.some((tag) => tag === slug))
	.sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf());

if (matching.length === 0) {
	return Astro.redirect("/404");
}

const posts = await Promise.all(
	matching.map(async (p) => {
		const { remarkPluginFrontmatter } = await render(p);
		const category = catFor(p.data.tags);
		return {
			category,
			tagLabel: category === "accessibility" ? "Accessibility" : "Creative coding",
			date: String(p.data.publishedDate.getFullYear()),
			readTime: remarkPluginFrontmatter.minutesRead as string,
			title: p.data.title,
			excerpt: p.data.description ?? "",
			url: `/post/${p.id}`,
			ariaLabel: `Read: ${p.data.title}`,
		};
	})
);

// Other tags to browse.
const otherTags = [...new Set(published.map((p) => p.data.tags).flat())]
	.filter((t) => t !== slug)
	.sort();

const count = posts.length;
---

<BaseLayout title={`Posts tagged ${slug} | Gwenaël Magnenat`} description={`All posts tagged ${slug}`}>
	<main id="main-content" tabindex="-1">
		<div class="page-wrap">
			<a href="/posts" class="back-link">← Blog</a>
			<p class="eyebrow">Tag</p>
			<h1 class="page-title">#{slug}</h1>
			<p class="page-count">{count} post{count !== 1 ? "s" : ""}</p>
		</div>

		<div class="page-wrap page-wrap--grid">
			<div class="posts-grid">
				{
					posts.map((post) => (
						<article class="post-card">
							<div class="post-meta">
								<span class={post.category === "accessibility" ? "tag tag-a11y" : "tag tag-creative"}>
									{post.tagLabel}
								</span>
								<span class="meta-text">{post.readTime} · {post.date}</span>
							</div>
							<h2 class="post-title">{post.title}</h2>
							<p class="post-excerpt">{post.excerpt}</p>
							<a href={post.url} class="read-link" aria-label={post.ariaLabel}>Read post →</a>
						</article>
					))
				}
			</div>

			{
				otherTags.length > 0 && (
					<div class="other-tags">
						<p class="eyebrow" style="margin-bottom: 1.25rem;">Other tags</p>
						<div class="tag-cloud">
							{otherTags.map((t) => (
								<a href={`/post/tags/${t}`} class="cloud-tag">#{t}</a>
							))}
						</div>
					</div>
				)
			}
		</div>
	</main>
</BaseLayout>

<style>
	.page-wrap { max-width: 1200px; margin: 0 auto; padding: 120px 2rem 0; }
	.page-wrap--grid { padding-top: 3rem; padding-bottom: 6rem; }

	.back-link {
		display: inline-block; font-size: 13px; font-weight: 600; color: #888;
		text-decoration: none; margin-bottom: 2.5rem; transition: color 0.15s;
	}
	.back-link:hover { color: #f0f0f0; }
	.eyebrow {
		font-size: 11px; font-weight: 600; letter-spacing: 0.18em;
		text-transform: uppercase; color: #888; margin-bottom: 1rem;
	}
	.page-title {
		font-size: clamp(36px, 5vw, 64px); font-weight: 700; letter-spacing: -0.04em;
		line-height: 1; color: #fff; margin-bottom: 1rem;
	}
	.page-count { font-size: 14px; color: #888; }

	.tag {
		font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
		padding: 3px 10px; border-radius: 100px; white-space: nowrap;
	}
	.tag-a11y { background: rgba(24,96,224,0.15); color: #7aadff; border: 1px solid rgba(24,96,224,0.3); }
	.tag-creative { background: rgba(20,160,140,0.15); color: #4dd9c4; border: 1px solid rgba(20,160,140,0.3); }
	.meta-text { font-size: 12px; color: #888; white-space: nowrap; }

	.posts-grid {
		display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 1px; background: #1e1e1e; border-top: 1px solid #1e1e1e;
	}
	.post-card {
		background: #0f0f0f; display: flex; flex-direction: column; gap: 1rem;
		padding: 2rem; border-bottom: 1px solid #1e1e1e; transition: background 0.15s;
	}
	.post-card:hover { background: #141414; }
	.post-meta { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
	.post-title { font-size: 17px; font-weight: 600; letter-spacing: -0.01em; line-height: 1.4; color: #f0f0f0; flex: 1; }
	.post-excerpt {
		font-size: 14px; color: #888; line-height: 1.75;
		display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
	}
	.read-link {
		font-size: 13px; font-weight: 600; color: #5b8ef5; text-decoration: none;
		display: inline-flex; align-items: center; gap: 4px; width: fit-content;
		margin-top: auto; transition: color 0.15s;
	}
	.read-link:hover { color: #7aaeff; }

	.other-tags { margin-top: 4rem; padding-top: 2.5rem; border-top: 1px solid #1e1e1e; }
	.tag-cloud { display: flex; flex-wrap: wrap; gap: 0.5rem; }
	.cloud-tag {
		font-size: 13px; font-weight: 500; padding: 5px 14px; border-radius: 100px;
		background: #161616; color: #aaa; border: 1px solid #242424; text-decoration: none;
		transition: border-color 0.15s, color 0.15s;
	}
	.cloud-tag:hover { color: #f0f0f0; border-color: #444; }
</style>
