---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "About";
const pageDescription =
	"About Gwenaël Magnenat — senior web developer and accessibility specialist in Lausanne, Switzerland.";

const skills = [
	{
		title: "Infrastructure & tooling",
		body: "I stand up what a team runs on day to day — Linux servers, deployment and monitoring pipelines, and a company-wide Monday.com rollout for project and time tracking.",
	},
	{
		title: "Web development",
		body: "I ship production sites and internal tools across the stack — WordPress with Oxygen and Bricks, Gatsby front-ends on a Sanity CMS, Nuxt and Laravel apps — and drop into whatever a team already runs.",
	},
	{
		title: "Working across teams",
		body: "I translate between the people writing the code and the people funding it — running projects with long-term clients and mentoring teammates to sharpen their skills and shared process.",
	},
	{
		title: "Project management",
		body: "I've run projects end to end on tight budgets and deadlines, and built an estimation system to scope and price new work before it starts.",
	},
];
---

<BaseLayout title=`${pageTitle} | Gwenaël Magnenat` description={pageDescription}>
	<main id="main-content" tabindex="-1">
		<div class="page-wrap">
			<!-- PAGE HEADER -->
			<header class="page-header">
				<p class="eyebrow">About</p>
				<h1 class="page-title">Gwenaël Magnenat</h1>
				<p class="page-subtitle">Web Developer &amp; Accessibility Specialist · Lausanne, Switzerland</p>
			</header>

			<p class="lead">
				I build web applications that are accessible to all. With a wide range of experience
				across web technologies, I am a team player and a clear communicator — as comfortable
				writing specs developers can act on as I am integrating into an existing stack.
			</p>

			<!-- WHAT I BRING -->
			<section aria-labelledby="bring-heading" class="section">
				<h2 id="bring-heading" class="section-heading">What I can bring</h2>
				<div class="skill-grid">
					{
						skills.map((s) => (
							<div class="skill-card">
								<h3 class="skill-title">{s.title}</h3>
								<p class="skill-body">{s.body}</p>
							</div>
						))
					}
				</div>
			</section>

			<!-- ON ACCESSIBILITY -->
			<aside aria-label="A note on accessibility focus" class="a11y-note">
				<p class="a11y-note-title">On accessibility</p>
				<p class="a11y-note-body">
					Digital accessibility is a central focus of my work — writing specs developers can
					act on, auditing products with real assistive technology rather than scanners alone,
					and advocating for it as a ship blocker rather than an afterthought. I can help you
					build a strategy for change and prepare your organization accordingly. I write about
					this three times a week on LinkedIn and keep a public blog on the topic.
				</p>
				<div class="a11y-note-links">
					<a href="https://linkedin.com/in/gmagnenat" target="_blank" rel="noopener noreferrer" class="note-link">LinkedIn writing ↗</a>
					<a href="/posts" class="note-link">Blog →</a>
				</div>
			</aside>

			<!-- CONTACT -->
			<section aria-labelledby="contact-heading" class="section">
				<h2 id="contact-heading" class="section-heading">Curious to know more?</h2>
				<p class="lead" style="margin-bottom: 1.75rem;">
					Social links are in the footer. If you prefer a form, there's one below.
				</p>
				<a href="https://tally.so/r/w5L5RN" target="_blank" rel="noopener noreferrer" class="contact-btn">
					Contact me<span class="sr-only"> (opens in a new tab)</span> ↗
				</a>
			</section>
		</div>
	</main>
</BaseLayout>

<style>
	.page-wrap { max-width: 1200px; margin: 0 auto; padding: 120px 2rem 80px; }
	.page-header { margin-bottom: 3rem; }
	.eyebrow {
		font-size: 11px; font-weight: 600; letter-spacing: 0.18em;
		text-transform: uppercase; color: #888; margin-bottom: 1rem;
	}
	.page-title {
		font-size: clamp(36px, 5vw, 64px); font-weight: 700; letter-spacing: -0.04em;
		line-height: 1; color: #fff; margin-bottom: 0.75rem;
	}
	.page-subtitle { font-size: 18px; color: #888; font-weight: 400; }

	.lead {
		font-size: 20px; font-weight: 500; letter-spacing: -0.015em; line-height: 1.55;
		color: #d0d0d0; max-width: 720px; margin-bottom: 5rem;
	}

	.section { margin-bottom: 5rem; }
	.section-heading {
		font-size: 11px; font-weight: 600; letter-spacing: 0.18em;
		text-transform: uppercase; color: #888; margin-bottom: 2.5rem;
	}

	.skill-grid {
		display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1px; background: #1e1e1e; border: 1px solid #1e1e1e;
	}
	.skill-card { background: #0f0f0f; padding: 1.75rem; }
	.skill-title { font-size: 20px; font-weight: 700; letter-spacing: -0.02em; color: #f0f0f0; margin-bottom: 0.75rem; }
	.skill-body { font-size: 15px; color: #888; line-height: 1.7; }

	.a11y-note {
		margin-bottom: 5rem; padding: 2rem 2.5rem;
		border-left: 2px solid #1860e0; background: rgba(24,96,224,0.06);
	}
	.a11y-note-title { font-size: 15px; font-weight: 600; color: #f0f0f0; margin-bottom: 0.5rem; }
	.a11y-note-body { font-size: 15px; color: #888; line-height: 1.75; max-width: 680px; }
	.a11y-note-links { display: flex; gap: 1rem; margin-top: 1.25rem; flex-wrap: wrap; }
	.note-link { font-size: 13px; font-weight: 600; color: #5b8ef5; text-decoration: none; transition: color 0.15s; }
	.note-link:hover { color: #7aaeff; }

	.contact-btn {
		display: inline-flex; align-items: center; gap: 0.4rem;
		font-size: 15px; font-weight: 600; color: #fff; text-decoration: none;
		background: #1860e0; padding: 11px 26px; border-radius: 100px; transition: background 0.15s;
	}
	.contact-btn:hover { background: #2472f5; color: #fff; }
</style>
