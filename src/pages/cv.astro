---
import { getCollection } from "astro:content";
import JobCard from "../components/JobCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = 'CV';

// Job filenames are numbered (01-donuts, 02-29-degres, ...) to encode the
// intended display order; sort by id to make that explicit rather than
// relying on getCollection()'s enumeration order.
const publishedJobs = (await getCollection('jobs', ({ data }) => {
    return data.draft !== true;
})).sort((a, b) => a.id.localeCompare(b.id, undefined, { numeric: true }));

---

<BaseLayout title=`${pageTitle} | Gwenaël Magnenat`>
	<div class="max-w-2xl flex flex-col gap-8 mx-auto">
		<h1 class="~text-4xl/5xl md:~text-5xl/6xl uppercase mt-10">{pageTitle}</h1>
    <h2 class="~text-2xl/4xl uppercase">work experience</h2>
		{
			publishedJobs.map((job) => {
				return <JobCard job={job} />
			})
		}

	</div>
</BaseLayout>