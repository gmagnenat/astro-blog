---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Blog";
const pageDescription = "Blog — Gwenaël Magnenat. Accessibility and creative coding.";

const catFor = (tags?: string[]) =>
	tags?.includes("accessibility") ? "accessibility" : "creative";

const published = await getCollection("posts", ({ data }) => data.draft !== true);
const sorted = published.sort(
	(a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf()
);

const posts = await Promise.all(
	sorted.map(async (p, i) => {
		const { remarkPluginFrontmatter } = await render(p);
		const category = catFor(p.data.tags);
		return {
			category,
			tagLabel: category === "accessibility" ? "Accessibility" : "Creative coding",
			date: String(p.data.publishedDate.getFullYear()),
			readTime: remarkPluginFrontmatter.minutesRead as string,
			title: p.data.title,
			excerpt: p.data.description ?? "",
			url: `/post/${p.id}`,
			ariaLabel: `Read: ${p.data.title}`,
			featured: i === 0,
		};
	})
);

const featured = posts[0];
---

<BaseLayout title=`${pageTitle} | Gwenaël Magnenat` description={pageDescription} bare={true}>
	<main id="main-content" tabindex="-1">
		<!-- PAGE HEADER -->
		<div class="page-wrap">
			<div class="blog-header">
				<div>
					<p class="eyebrow">Blog</p>
					<h1 class="page-title">Writing</h1>
					<p class="page-intro">
						Two things I think about: accessibility — the practice, not the checklist — and
						what happens when code becomes the medium.
					</p>
				</div>
				<div role="group" aria-label="Filter posts by topic" class="filters">
					<button class="filter-tab is-active" data-filter="all" aria-pressed="true">All</button>
					<button class="filter-tab" data-filter="accessibility" aria-pressed="false">Accessibility</button>
					<button class="filter-tab" data-filter="creative" aria-pressed="false">Creative coding</button>
				</div>
			</div>
		</div>

		<p id="filter-status" aria-live="polite" aria-atomic="true" class="sr-only"></p>

		<!-- FEATURED POST (shown only in the All view) -->
		{
			featured && (
				<div id="featured-wrap" class="page-wrap page-wrap--flush">
					<a href={featured.url} class="featured-link" aria-label={featured.ariaLabel}>
						<div class="featured">
							<div>
								<div class="featured-meta">
									<span class={featured.category === "accessibility" ? "tag tag-a11y" : "tag tag-creative"}>
										{featured.tagLabel}
									</span>
									<span class="meta-text">{featured.readTime} · {featured.date}</span>
								</div>
								<h2 class="featured-title">{featured.title}</h2>
							</div>
							<div class="featured-body">
								<p class="featured-excerpt">{featured.excerpt}</p>
								<span class="featured-read">Read →</span>
							</div>
						</div>
					</a>
				</div>
			)
		}

		<!-- POSTS GRID -->
		<div class="page-wrap page-wrap--grid">
			<div id="posts-grid" class="posts-grid">
				{
					posts.map((post) => (
						<article class="post-card" data-category={post.category} data-featured={String(post.featured)}>
							<div class="post-meta">
								<span class={post.category === "accessibility" ? "tag tag-a11y" : "tag tag-creative"}>
									{post.tagLabel}
								</span>
								<span class="meta-text">{post.readTime} · {post.date}</span>
							</div>
							<h2 class="post-title">{post.title}</h2>
							<p class="post-excerpt">{post.excerpt}</p>
							<a href={post.url} class="read-link" aria-label={post.ariaLabel}>Read post →</a>
						</article>
					))
				}
			</div>
		</div>

		<!-- LINKEDIN CTA -->
		<div class="cta">
			<div class="cta-inner">
				<p class="eyebrow" style="margin-bottom: 1.25rem;">More writing</p>
				<p class="cta-title">3× a week on LinkedIn — in French</p>
				<p class="cta-body">
					Shorter takes on real accessibility problems in real products. The kind of thing that
					doesn't make it into a blog post but that I think about constantly.
				</p>
				<a href="https://linkedin.com/in/gmagnenat" target="_blank" rel="noopener noreferrer" class="cta-btn">
					Follow on LinkedIn ↗
				</a>
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page-wrap { max-width: 1200px; margin: 0 auto; padding: 120px 2rem 0; }
	.page-wrap--flush { padding-top: 0; padding-bottom: 0; }
	.page-wrap--grid { padding-top: 0; padding-bottom: 6rem; }

	.blog-header {
		display: flex; align-items: flex-end; justify-content: space-between;
		gap: 2rem; flex-wrap: wrap; padding-bottom: 3rem; border-bottom: 1px solid #1e1e1e;
	}
	.eyebrow {
		font-size: 11px; font-weight: 600; letter-spacing: 0.18em;
		text-transform: uppercase; color: #888; margin-bottom: 1rem;
	}
	.page-title {
		font-size: clamp(36px, 5vw, 64px); font-weight: 700; letter-spacing: -0.04em;
		line-height: 1; color: #fff; margin-bottom: 1rem;
	}
	.page-intro { font-size: 16px; color: #888; max-width: 480px; line-height: 1.6; }

	.filters { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; padding-bottom: 0.25rem; }
	.filter-tab {
		padding: 7px 20px; border-radius: 100px; border: 1px solid #252525;
		background: transparent; color: #999; cursor: pointer;
		font-size: 13px; font-weight: 500; font-family: inherit;
		transition: all 0.15s ease; white-space: nowrap;
	}
	.filter-tab.is-active { border-color: #1860e0; background: #1860e0; color: #fff; }

	.tag {
		font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
		padding: 3px 10px; border-radius: 100px; white-space: nowrap;
	}
	.tag-a11y { background: rgba(24,96,224,0.15); color: #7aadff; border: 1px solid rgba(24,96,224,0.3); }
	.tag-creative { background: rgba(20,160,140,0.15); color: #4dd9c4; border: 1px solid rgba(20,160,140,0.3); }
	.meta-text { font-size: 12px; color: #888; white-space: nowrap; }

	/* Featured */
	.featured-link { text-decoration: none; color: inherit; display: block; }
	.featured-link:hover .featured-title { color: #fff; }
	.featured-link:focus-visible { outline: 2px solid #1860e0; outline-offset: 4px; border-radius: 2px; }
	.featured {
		padding: 3.5rem 0; border-bottom: 1px solid #1e1e1e;
		display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;
	}
	.featured-meta { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.75rem; flex-wrap: wrap; }
	.featured-title {
		font-size: clamp(24px, 3vw, 40px); font-weight: 700; letter-spacing: -0.03em;
		line-height: 1.15; color: #f0f0f0; transition: color 0.15s;
	}
	.featured-body { padding-top: 0.25rem; }
	.featured-excerpt { font-size: 16px; color: #888; line-height: 1.8; margin-bottom: 2rem; }
	.featured-read { font-size: 14px; font-weight: 600; color: #5b8ef5; }

	/* Grid */
	.posts-grid {
		display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 1px; background: #1e1e1e; margin-top: 1px;
	}
	.post-card {
		background: #0f0f0f; display: flex; flex-direction: column; gap: 1rem;
		padding: 2rem; border-bottom: 1px solid #1e1e1e; transition: background 0.15s;
	}
	.post-card:hover { background: #141414; }
	.post-meta { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
	.post-title { font-size: 17px; font-weight: 600; letter-spacing: -0.01em; line-height: 1.4; color: #f0f0f0; flex: 1; }
	.post-excerpt {
		font-size: 14px; color: #888; line-height: 1.75;
		display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
	}
	.read-link {
		font-size: 13px; font-weight: 600; color: #5b8ef5; text-decoration: none;
		display: inline-flex; align-items: center; gap: 4px; width: fit-content;
		margin-top: auto; transition: color 0.15s;
	}
	.read-link:hover { color: #7aaeff; }

	@media (max-width: 640px) {
		.featured { grid-template-columns: 1fr; gap: 1.5rem; }
	}

	/* CTA */
	.cta { background: #0b0b0b; border-top: 1px solid #1e1e1e; padding: 4rem 2rem; }
	.cta-inner { max-width: 640px; margin: 0 auto; text-align: center; }
	.cta-title { font-size: 22px; font-weight: 600; letter-spacing: -0.02em; color: #f0f0f0; line-height: 1.4; margin-bottom: 0.75rem; }
	.cta-body { font-size: 15px; color: #888; line-height: 1.7; margin-bottom: 2rem; }
	.cta-btn {
		display: inline-flex; align-items: center; gap: 0.5rem;
		font-size: 15px; font-weight: 600; color: #fff; text-decoration: none;
		background: #0A66C2; padding: 12px 28px; border-radius: 6px; white-space: nowrap; transition: background 0.15s;
	}
	.cta-btn:hover { background: #0958aa; color: #fff; }
</style>

<script>
	const tabs = document.querySelectorAll<HTMLButtonElement>(".filter-tab");
	const cards = document.querySelectorAll<HTMLElement>("#posts-grid .post-card");
	const featuredWrap = document.getElementById("featured-wrap");
	const status = document.getElementById("filter-status");

	function applyFilter(filter: string) {
		const showFeatured = filter === "all";
		if (featuredWrap) featuredWrap.style.display = showFeatured ? "block" : "none";

		let visible = showFeatured ? 1 : 0;
		cards.forEach((card) => {
			// In the All view, the featured post already shows above — hide its card.
			const isFeatured = card.dataset.featured === "true";
			const show = showFeatured
				? !isFeatured
				: card.dataset.category === filter;
			card.style.display = show ? "flex" : "none";
			if (show) visible++;
		});

		tabs.forEach((t) => {
			const active = t.dataset.filter === filter;
			t.classList.toggle("is-active", active);
			t.setAttribute("aria-pressed", String(active));
		});

		if (status) {
			const label =
				filter === "all" ? "" : filter === "accessibility" ? " in Accessibility" : " in Creative coding";
			status.textContent = `Showing ${visible} post${visible !== 1 ? "s" : ""}${label}`;
		}
	}

	tabs.forEach((t) => t.addEventListener("click", () => applyFilter(t.dataset.filter || "all")));
	applyFilter("all");
</script>
