---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import BaseLayout from './BaseLayout.astro';

interface Props {
    post: CollectionEntry<'posts'>;
    minutesRead?: string;
}

const { post, minutesRead } = Astro.props;
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/**/*.{jpeg,jpg,png,gif}');
const postImages: string[] = [];

Object.entries(images).map(([key]) => {
  if (key.startsWith(`/src/assets/${post.id}/slider/`)) postImages.push(key);
})

const dateStr = post.data.publishedDate.toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric',
});
---
<BaseLayout title={post.data.title} description={post.data.description} ogType="article" image={post.data.postimage!.src}>
    <main id="main-content" tabindex="-1">
        <article>
            <!-- HEADER -->
            <div class="post-head">
                <a href="/posts" class="back-link">← Blog</a>
                <div class="post-tags" role="list" aria-label="Tags">
                    {post.data.tags.map((tag) => (
                        <a role="listitem" href={`/post/tags/${tag}`} class={tag === 'accessibility' ? 'tag tag-accent' : 'tag'}>{tag}</a>
                    ))}
                </div>
                <h1 class="post-title">{post.data.title}</h1>
                <p class="post-meta">{minutesRead ? `${minutesRead} · ` : ''}{dateStr}</p>
            </div>

            <!-- HERO IMAGE -->
            <figure class="post-hero">
                <Image
                    src={post.data.postimage!.src}
                    alt={post.data.postimage!.alt}
                    class="post-hero-img"
                />
            </figure>

            <!-- BODY -->
            <div class="post-column">
                <p class="post-lead">{post.data.description}</p>
                <div class="post__content">
                    <slot />
                </div>

                {postImages.length > 0 && (
                    <div class="post-gallery">
                        {postImages.map((image) => (
                            <Image
                                src={images[image]()}
                                alt={post.data.title}
                                width={1080}
                                height={1080}
                                class="post-gallery-img"
                            />
                        ))}
                    </div>
                )}

                <div class="post-footer">
                    <a href="/posts" class="back-link">← Back to all writing</a>
                </div>
            </div>
        </article>
    </main>
</BaseLayout>

<style>
    .post-head { max-width: 760px; margin: 0 auto; padding: 120px 2rem 0; }
    .back-link {
        display: inline-block; font-size: 13px; font-weight: 600; color: #888;
        text-decoration: none; margin-bottom: 2.5rem; transition: color 0.15s;
    }
    .back-link:hover { color: #f0f0f0; }
    .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem; }
    .tag {
        font-size: 11px; font-weight: 500; padding: 4px 12px; border-radius: 100px;
        background: #161616; color: #aaa; border: 1px solid #242424; text-decoration: none;
        transition: border-color 0.15s, color 0.15s;
    }
    .tag:hover { color: #f0f0f0; border-color: #444; }
    .tag-accent {
        font-weight: 600; letter-spacing: 0.04em;
        background: rgba(24,96,224,0.15); color: #7aadff; border-color: rgba(24,96,224,0.3);
    }
    .tag-accent:hover { color: #a9caff; }
    .post-title {
        font-size: clamp(30px, 4.5vw, 52px); font-weight: 700; letter-spacing: -0.035em;
        line-height: 1.1; color: #fff; margin-bottom: 1rem;
    }
    .post-meta { font-size: 14px; color: #888; }

    .post-hero { max-width: 960px; margin: 3.5rem auto 0; padding: 0 2rem; }
    .post-hero-img {
        width: 100%; height: clamp(240px, 42vw, 460px); object-fit: cover;
        border-radius: 10px; border: 1px solid #1e1e1e;
    }

    .post-column { max-width: 760px; margin: 0 auto; padding: 3.5rem 2rem 2rem; }
    .post-lead {
        font-size: clamp(18px, 2.2vw, 22px); font-weight: 500; line-height: 1.55;
        letter-spacing: -0.01em; color: #d0d0d0; margin-bottom: 2.5rem;
        padding-bottom: 2.5rem; border-bottom: 1px solid #1e1e1e;
    }

    .post-gallery {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 0.75rem; margin: 3rem 0;
    }
    .post-gallery-img { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 6px; }

    .post-footer { margin-top: 4rem; padding-top: 2rem; border-top: 1px solid #1e1e1e; }
    .post-footer .back-link { margin-bottom: 0; }
</style>
